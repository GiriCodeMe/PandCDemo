# ── Google AI Studio (default) ──────────────────────────────────────────────
# Free tier + pay-as-you-go. API key from https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Base URL for the Gemini API.
# The SDK appends:  /{GEMINI_API_VERSION}/models/{model}:{task}
# Final request:    {GEMINI_BASE_URL}/{GEMINI_API_VERSION}/models/gemini-2.0-flash:generateContent
#
# Option 1 — Google AI Studio (default, API-key auth)
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
#
# Model to use (default: gemini-2.0-flash-lite)
# Other options: gemini-2.0-flash, gemini-1.5-flash, gemini-1.5-pro
GEMINI_MODEL=gemini-2.0-flash-lite
#
# Option 2 — Corporate / enterprise proxy in front of Google AI
# GEMINI_BASE_URL=https://ai-proxy.your-company.com
#
# Option 3 — Local mock server (e.g. for offline demos / CI)
# GEMINI_BASE_URL=http://localhost:4000
#
# NOTE — Vertex AI requires a separate SDK (@google-cloud/vertexai),
# OAuth2 / service-account auth, and project/location in the path.
# It cannot be used by changing GEMINI_BASE_URL alone.
# Vertex AI endpoint shape (for reference only):
#   https://{region}-aiplatform.googleapis.com/v1/projects/{PROJECT_ID}/locations/{REGION}/publishers/google/models/{MODEL}:generateContent

# API version sent to the endpoint (default used by SDK: v1beta)
# Switch to v1 for stable/GA features only
# GEMINI_API_VERSION=v1beta

PORT=3001
